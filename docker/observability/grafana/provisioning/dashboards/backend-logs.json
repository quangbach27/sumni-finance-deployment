{
  "title": "Backend Logs",
  "uid": "backend-logs",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "correlation_id",
        "label": "Correlation ID",
        "description": "Filter logs by correlation_id. Leave empty to show all.",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "options": [],
        "query": ""
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "current": { "selected": true, "text": "All", "value": ".*" },
        "options": [
          { "selected": true, "text": "All", "value": ".*" },
          { "selected": false, "text": "info",  "value": "info" },
          { "selected": false, "text": "warn",  "value": "warn" },
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "debug", "value": "debug" }
        ],
        "hide": 0,
        "query": ".*,info,warn,error,debug"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "sumni-finance-backend",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"sumni-finance-backend\"} | json | level=~\"${level}\" |~ \"${correlation_id:raw}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "links": []
}
